{
  "name": "@liraintelligence/support",
  "version": "0.3.0",
  "description": "Lira Support Web SDK for full-page support embeds, floating widgets, identity, context, and customer actions.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://docs.liraintelligence.com/platform/customer-support/web-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/liraintelligence/lira-ai"
  },
  "keywords": [
    "lira",
    "support",
    "ai",
    "chat",
    "tickets",
    "widget",
    "customer-support",
    "react"
  ],
  "sideEffects": false,
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs"
    },
    "./react": {
      "types": "./react.d.ts",
      "import": "./react.mjs",
      "require": "./react.cjs"
    }
  },
  "files": [
    "*.js",
    "*.mjs",
    "*.cjs",
    "*.d.ts",
    "cli.cjs",
    "templates",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "bin": {
    "lira": "./cli.cjs",
    "lira-init": "./cli.cjs",
    "support": "./cli.cjs"
  },
  "publishConfig": {
    "access": "public"
  }
}

# Lira AI — environment variables
# Copy to .env for local development.
#
# NOTE: VITE_* variables are BUILD-TIME config values baked into the JS bundle.
# They are visible to anyone in DevTools — do NOT put real secrets here.
# Real secrets (JWT_SECRET, DATABASE_URL, etc.) live on the backend via AWS Secrets Manager.

# Backend API base URL (REST)
VITE_API_URL=https://api.creovine.com

# Backend WebSocket base URL
VITE_WS_URL=wss://api.creovine.com/lira/v1/ws

# Google OAuth Client ID for Lira user sign-in.
# Use the Google Sign-In client from the dedicated Lira Google Cloud project.
VITE_GOOGLE_LOGIN_CLIENT_ID=

# Legacy fallback during migration only
# VITE_GOOGLE_CLIENT_ID=
